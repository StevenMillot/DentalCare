# =====================================================
# CONFIGURATION OVH CLOUD - PARO-SPE.FR
# =====================================================
# ⚠️  INSTRUCTIONS IMPORTANTES:
# 1. Copiez ce fichier en .env.ovh
# 2. Remplissez vos identifiants OVH
# 3. NE JAMAIS commiter le fichier .env.ovh (déjà dans .gitignore)
# =====================================================

# ------------------------------------------------------
# CONNEXION FTP/SFTP OVH - PRODUCTION
# ------------------------------------------------------

# Hôte FTP OVH (trouvable dans l'espace client OVH)
# Format: ftp.clusterXXX.hosting.ovh.net (où XXX est votre numéro de cluster)
FTP_HOST=ftp.cluster0XX.hosting.ovh.net

# Login FTP (généralement votre nom de domaine ou un sous-compte)
FTP_USER=votre-login-ftp

# Mot de passe FTP
FTP_PASS=votre-mot-de-passe-ftp

# Port FTP (généralement 21 pour FTP, 22 pour SFTP)
FTP_PORT=21

# Répertoire distant où déployer le site
# Sur OVH mutualisé, c'est généralement /www ou /
FTP_REMOTE_DIR=/www


# ------------------------------------------------------
# CONNEXION STAGING (OPTIONNEL)
# ------------------------------------------------------
# Si vous avez un environnement de staging/test

FTP_HOST_STAGING=ftp.cluster0XX.hosting.ovh.net
FTP_USER_STAGING=votre-login-ftp-staging
FTP_PASS_STAGING=votre-mot-de-passe-ftp-staging
FTP_PORT_STAGING=21
FTP_REMOTE_DIR_STAGING=/staging


# ------------------------------------------------------
# OPTIONS DE SÉCURITÉ
# ------------------------------------------------------

# Utiliser SFTP au lieu de FTP ? (plus sécurisé, mais parfois non disponible sur mutualisé)
# Valeurs: true ou false
USE_SFTP=false

# Port SFTP (généralement 22)
SFTP_PORT=22


# ------------------------------------------------------
# OPTIONS DE DÉPLOIEMENT
# ------------------------------------------------------

# Créer un backup avant chaque déploiement ?
# Valeurs: true ou false
CREATE_BACKUP=true

# Supprimer les fichiers distants qui n'existent plus en local ?
# Valeurs: true ou false
DELETE_REMOTE=true


# ------------------------------------------------------
# DOMAINE ET URL
# ------------------------------------------------------

# URL de production du site
SITE_URL=https://paro-spe.fr

# Email de l'administrateur
ADMIN_EMAIL=contact@paro-spe.fr


# ------------------------------------------------------
# MONITORING ET ALERTES (OPTIONNEL)
# ------------------------------------------------------

# Webhook Discord pour les notifications de déploiement (optionnel)
DISCORD_WEBHOOK_URL=

# Clé API pour service de monitoring (optionnel)
MONITORING_API_KEY=


# =====================================================
# COMMENT TROUVER VOS IDENTIFIANTS OVH:
# =====================================================
#
# 1. Connectez-vous à votre espace client OVH:
#    https://www.ovh.com/manager/
#
# 2. Allez dans "Hébergements" > Sélectionnez votre hébergement
#
# 3. Onglet "FTP-SSH":
#    - Vous y trouverez:
#      * Le serveur FTP (FTP_HOST)
#      * Le login principal (FTP_USER)
#      * Vous pouvez modifier le mot de passe (FTP_PASS)
#
# 4. Le répertoire distant est généralement /www
#    Vous pouvez vous connecter avec FileZilla pour vérifier
#
# 5. Pour SFTP, vérifiez si votre offre le supporte dans
#    l'onglet "FTP-SSH" > "SSH"
#
# =====================================================
